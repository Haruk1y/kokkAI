{
  "name": "kokkai-prototype",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "kokkai-prototype",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20.0.0"
      }
    },
    "apps/api": {
      "name": "@kokkai/api",
      "version": "0.1.0"
    },
    "apps/web": {
      "name": "@kokkai/web",
      "version": "0.1.0"
    },
    "node_modules/@kokkai/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@kokkai/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@kokkai/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@kokkai/shared",
      "version": "0.1.0"
    }
  }
}
