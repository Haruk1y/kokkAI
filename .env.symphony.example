# Required for Symphony's Linear tracker integration.
LINEAR_API_KEY=replace-with-linear-api-key

# Default repo cloned into each issue workspace.
SOURCE_REPO_URL=git@github.com:Haruk1y/kokkAI.git

# Workspace root for per-issue clones created by Symphony.
SYMPHONY_WORKSPACE_ROOT=/Users/yajima/Desktop/dev/symphony-workspaces/kokkAI

# Optional observability UI port used when launching Symphony with --port.
SYMPHONY_PORT=4050
